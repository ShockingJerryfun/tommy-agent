# Copy this file to .env and fill in your own values.
# The backend picks up the first key it finds in this order:
#   DEEPSEEK_API_KEY -> OPENROUTER_API_KEY -> OPENAI_API_KEY

# --- DeepSeek (recommended) ---
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- OpenRouter ---
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=deepseek/deepseek-chat

# --- OpenAI ---
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o

# --- Optional tuning ---
# AGENT_TEMPERATURE=0.2
# AGENT_TIMEOUT_SECONDS=60
# AGENT_MAX_RETRIES=2
# AGENT_WORKSPACE_ROOT=/absolute/path/to/your/project
# Local file tools default to your home directory. Set to / only if you want
# the local agent to attempt full-disk paths permitted by macOS permissions.
# AGENT_FILE_ACCESS_ROOT=/absolute/path/to/allowed/files

# --- PostgreSQL ---
# Runtime state and LangGraph checkpoints are stored in PostgreSQL.
TOMMY_POSTGRES_DSN=dbname=tommy_agent
# Tests use TOMMY_TEST_POSTGRES_DSN and refuse to reset non-test databases.
# The default pytest database is created automatically when needed.
# TOMMY_TEST_POSTGRES_DSN=dbname=tommy_agent_test

# --- Web search ---
# Enables the agent's Tavily-backed web_search tool.
# TAVILY_API_KEY=your_tavily_api_key

# --- Frontend / CORS ---
# Optional comma-separated allow-list. Localhost is allowed by default.
# FRONTEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
